# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection
# Get your connection string from: https://www.mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<app-name>

# JWT Secret Key (Generate a strong secret key)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here

# Frontend URL (for CORS)
FRONTEND_URL=https://homemade-food.vercel.app

# Cloudflare R2 Object Storage
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=homemadefood
R2_PUBLIC_URL=https://your-public-bucket-url.r2.dev
